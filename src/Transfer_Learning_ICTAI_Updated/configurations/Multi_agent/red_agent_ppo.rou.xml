<?xml version="1.0" encoding="UTF-8"?>

<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- Original supervisor part -->
    <vehicle id="v_red" depart="0.00" color="red">
        <route edges="-E0 E1"/>
    </vehicle>

    <!-- Original supervisor traffic flow -->
    <flow id="f_0"
          begin="0.00"
          from="E0"
          to="E1"
          end="36000.00"
          period="exp(3.6)"/>


    <!--
        Extra random vehicle for PPO validation test.
        It is placed on a different route from the controlled red vehicle.
        This adds randomness in the environment without directly blocking v_red.
    -->
    
    <vType id="green_random_type"
           color="green"
           accel="2.6"
           decel="4.5"
           sigma="0.5"
           maxSpeed="13.89"
           speedFactor="normc(1.0,0.15,0.6,1.4)"/>

    <vehicle id="green_random_vehicle"
             type="green_random_type"
             depart="0.00"
             departSpeed="random">
        <route edges="E0 E0.69"/>
    </vehicle>

</routes>